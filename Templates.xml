<Ui xmlns="http://www.blizzard.com/wow/ui/">
	<EditBox name="BJ_InputBoxScriptTemplate" enableMouse="true" virtual="true">
		<Scripts>
			<OnTabPressed function="EditBox_OnTabPressed"/>
			<OnEscapePressed function="EditBox_ClearFocus"/>
			<OnEditFocusLost function="EditBox_ClearHighlight"/>
			<OnEditFocusGained function="EditBox_HighlightText"/>
		</Scripts>
	</EditBox>

	<EditBox name="BJ_InputBoxVisualTemplate" virtual="true">
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Right" file="interface/common/commonsearch">
					<Size x="8" y="20"/>
					<Anchors>
						<Anchor point="RIGHT" x="0" y="0"/>
					</Anchors>
					<TexCoords left="0" right="0.07" top=".338" bottom=".638"/>
				</Texture>
				<Texture parentKey="Left" file="interface/common/commonsearch">
					<Size x="8" y="20"/>
					<Anchors>
						<Anchor point="LEFT" x="-5" y="0"/>
					</Anchors>
					<TexCoords left=".88" right=".95" top=".01" bottom=".31"/>
				</Texture>
				<Texture parentKey="Middle" file="interface/common/commonsearch">
					<Size x="10" y="20"/>
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.Left" relativePoint="RIGHT"/>
						<Anchor point="RIGHT" relativeKey="$parent.Right" relativePoint="LEFT"/>
					</Anchors>
					<TexCoords left="0" right="0.8" top=".01" bottom=".31"/>
				</Texture>
			</Layer>
		</Layers>
		<FontString inherits="ChatFontNormal"/>
	</EditBox>

	<EditBox name="BJ_InputBoxTemplate" inherits="BJ_InputBoxScriptTemplate, BJ_InputBoxVisualTemplate" virtual="true"/>


	<EditBox name="BJ_InputBoxInstructionsTemplate" inherits="BJ_InputBoxTemplate" virtual="true">
		<!--KeyValues>
				Optional
				<KeyValue key="disabledColor" value="GRAY_FONT_COLOR" type="global"/>
				<KeyValue key="enabledColor" value="HIGHLIGHT_FONT_COLOR" type="global"/>
			</KeyValues-->
		<Layers>
			<Layer level="ARTWORK">
				<FontString parentKey="Instructions" justifyH="LEFT" justifyV="MIDDLE" inherits="GameFontDisableSmall" setAllPoints="true">
					<Color r="0.35" g="0.35" b="0.35"/>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnTextChanged function="InputBoxInstructions_OnTextChanged"/>
			<OnDisable function="InputBoxInstructions_OnDisable"/>
			<OnEnable function="InputBoxInstructions_OnEnable"/>
		</Scripts>
		<FontString inherits="GameFontHighlightSmall"/>
	</EditBox>
</Ui>